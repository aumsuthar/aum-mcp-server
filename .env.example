# GitHub — generate at github.com/settings/tokens with read:user scope
GITHUB_TOKEN=""

# Canvas LMS — generate at osu.instructure.com > Account > Settings > New Access Token
CANVAS_TOKEN=""

# Spotify — create app at developer.spotify.com, set redirect URI to /stats
SPOTIFY_CLIENT_ID=""
SPOTIFY_REFRESH_TOKEN=""

# Supabase — used to cache the Spotify access token
SUPABASE_URL=""
SUPABASE_KEY=""
