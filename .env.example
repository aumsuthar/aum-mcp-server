# ─── Developer ────────────────────────────────────────────────────────────────

# GitHub — generate at github.com/settings/tokens (read:user scope)
GITHUB_TOKEN=""

# Canvas LMS — generate at your institution's Canvas > Account > Settings > New Access Token
CANVAS_TOKEN=""

# Spotify — create an app at developer.spotify.com
SPOTIFY_CLIENT_ID=""
SPOTIFY_REFRESH_TOKEN=""

# Supabase — used to cache the Spotify access token (optional but recommended)
SUPABASE_URL=""
SUPABASE_KEY=""

# Ollama — optional, defaults to http://localhost:11434
# OLLAMA_HOST=""

# ─── Notes ────────────────────────────────────────────────────────────────────

# Obsidian vault — absolute path to your vault directory on this device
OBSIDIAN_VAULT_PATH=""   # e.g. /Users/you/Documents/Obsidian Vault

# ─── Communication ────────────────────────────────────────────────────────────

# Google (Gmail + Calendar + Contacts)
# 1. Create a project at console.cloud.google.com
# 2. Enable Gmail API, Calendar API, and People API
# 3. Create OAuth 2.0 credentials (Desktop app)
# 4. Run: node --env-file=.env scripts/google-auth.mjs
#    This prints a GOOGLE_REFRESH_TOKEN — paste it below
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""

# iMessage — no API key needed, uses macOS Messages.app via AppleScript
# Requires Full Disk Access for the terminal app running Claude Code

# ─── SLURM / HPC ──────────────────────────────────────────────────────────────

# SSH credentials for your SLURM cluster
SLURM_HOST=""          # e.g. login.hpc.university.edu
SLURM_USERNAME=""
SLURM_PASSWORD=""
