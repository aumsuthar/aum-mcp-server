{
  "name": "aum-mcp-server",
  "version": "1.0.0",
  "description": "Aum's personal MCP server — a unified API hub for Claude",
  "main": "dist/index.js",
  "bin": {
    "aum-developer": "./dist/developer.js",
    "aum-notes": "./dist/notes-server.js",
    "aum-communication": "./dist/communication.js",
    "aum-canvas": "./dist/canvas-server.js",
    "aum-personal": "./dist/personal.js",
    "aum-slurm": "./dist/slurm.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx --env-file=.env src/index.ts",
    "dev:developer": "tsx --env-file=.env src/developer.ts",
    "dev:notes": "tsx --env-file=.env src/notes-server.ts",
    "dev:communication": "tsx --env-file=.env src/communication.ts",
    "dev:canvas": "tsx --env-file=.env src/canvas-server.ts",
    "dev:personal": "tsx --env-file=.env src/personal.ts",
    "dev:slurm": "tsx --env-file=.env src/slurm.ts",
    "web": "tsx --env-file=.env src/web.ts"
  },
  "keywords": [
    "mcp",
    "claude",
    "api"
  ],
  "author": "Aum Suthar",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "docx": "^9.6.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pptxgenjs": "^4.0.1",
    "ssh2": "^1.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.4.0",
    "@types/ssh2": "^1.15.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
